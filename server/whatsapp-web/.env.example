# Copy to .env and fill in. NEVER commit the real .env.

# Port the service listens on
PORT=8787

# Shared secret the app must send as `x-api-key`. Pick a long random string and
# enter the SAME value in Establishment Master → WhatsApp → API Key.
API_KEY=change-me-to-a-long-random-string

# Where the app is served from (for CORS). Use your app origin, or * for dev.
ALLOW_ORIGIN=http://localhost:5173

# Supabase — so the service can write delivery acks into whatsapp_notifications.
# Use the SERVICE ROLE key (server-side only; never put it in the front-end app).
SUPABASE_URL=https://cngmweuxrrhvneiryajn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: where to persist the WhatsApp session (mount a persistent disk here in prod).
SESSION_PATH=./.wwebjs_auth
